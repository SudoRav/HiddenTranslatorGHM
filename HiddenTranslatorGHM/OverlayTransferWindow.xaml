<Window x:Class="HiddenTranslatorGHM.OverlayTransferWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="800"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen">

    <Grid >
        <!-- Полупрозрачный задний фон -->
        <Border x:Name="BRD_Background"
                Background="#80000000"
                Padding="15"
                CornerRadius="12"
                SnapsToDevicePixels="True"
                Opacity="0"
                Margin="0,400,0,0">
            <StackPanel>
                <!-- Текст ниже -->
                <TextBlock x:Name="TB_OverlayTemporaryText"
                           Text=""
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Foreground="White"
                           FontSize="20"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>