<Window x:Class="HiddenTranslatorGHM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hotkey Manager" Height="460" Width="620"
        Background="#23272A">
    <Grid Margin="12,12,12,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Нажмите комбинацию в поле, затем Сохранить" FontSize="13" Foreground="White"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,8">
            <TextBox x:Name="HotkeyBox"
                     Width="300"
                     Height="30"
                     FontSize="14"
                     IsReadOnly="True"
                     PreviewKeyDown="HotkeyBox_PreviewKeyDown"
                     PreviewKeyUp="HotkeyBox_PreviewKeyUp"
                     VerticalContentAlignment="Center"/>
            <Button Content="Сохранить" Margin="8,0,0,0" Width="90" Click="SaveHotkey_Click"/>
            <Button Content="Очистить поле" Margin="8,0,0,0" Width="100" Click="ClearField_Click"/>
        </StackPanel>

        <GroupBox Grid.Row="2" Header="Сохранённые хоткеи" Margin="0,0,0,8" Foreground="White">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ListBox x:Name="HotkeysList" Margin="0,10,0,0" ItemsSource="{Binding _hotkeys}" Background="#23272A" Foreground="White">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="5">
                                <Grid.ColumnDefinitions>
                                    <!-- первая колонка: минимум 180, но может расширяться -->
                                    <ColumnDefinition Width="Auto" MinWidth="180"/>
                                    <!-- вторая колонка (чекбокс) фиксированная -->
                                    <ColumnDefinition Width="100"/>
                                    <!-- третья колонка: минимум 140, но подстраивается -->
                                    <ColumnDefinition Width="Auto" MinWidth="140"/>
                                    <!-- четвёртая колонка (кнопка удаления) авто -->
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Название хоткея -->
                                <TextBlock Text="{Binding Display}" VerticalAlignment="Center" Grid.Column="0"/>

                                <!-- Флаг PassThrough -->
                                <CheckBox Content="Пропускать"
                                          IsChecked="{Binding PassThrough, Mode=TwoWay}"
                                          Checked="HotkeyPropertyChanged"
                                          Unchecked="HotkeyPropertyChanged"
                                          VerticalAlignment="Center"
                                          Grid.Column="1"
                                          Foreground="White"/>

                                <!-- Выбор действия -->
                                <ComboBox Width="200"
                                          ItemsSource="{Binding DataContext.AvailableActions, RelativeSource={RelativeSource AncestorType=Window}}"
                                          SelectedItem="{Binding ActionName, Mode=TwoWay}"
                                          SelectionChanged="HotkeyPropertyChanged"
                                          Grid.Column="2"/>

                                <!-- Кнопка удаления -->
                                <Button Content="Удалить"
                                        Click="DeleteHotkey_Click"
                                        Tag="{Binding Id}"
                                        Margin="10,0,0,0"
                                        Grid.Column="3"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>
        </GroupBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Left">
            <Button Content="Удалить все хоткеи" Click="ClearHotkeys_Click" Width="160"/>
            <Button Content="Сбросить все хоткеи" Click="ResetHotkeys_Click" Width="160" Margin="8,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>