<Window x:Class="HiddenTranslatorGHM.OverlayWordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="1000"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen">

    <Grid >
        <!-- Полупрозрачный задний фон -->
        <Border x:Name="BRD_Background"
                Background="#80000000"
                Padding="15"
                CornerRadius="12"
                SnapsToDevicePixels="True" MouseEnter="BRD_Background_MouseEnter">
            <StackPanel>

                <!-- Поле ввода -->
                <TextBox x:Name="TBx_OverlayWord"
                         Text=""
                         TextAlignment="Center"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="White"
                         FontSize="20"
                         VerticalAlignment="Center"
                         SpellCheck.IsEnabled="True"
                         CaretBrush="White"
                         TextChanged="TBx_OverlayWord_TextChanged"/>

                <!-- Текст ниже -->
                <TextBlock x:Name="TB_OverlayText"
                           Text=""
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Foreground="White"
                           FontSize="20"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
